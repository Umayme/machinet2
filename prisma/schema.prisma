generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  password      String
  name          String
  phone         String?
  company       String?
  wilaya        String?
  sector        String?
  role          String         @default("buyer")
  approved      Boolean        @default(false)
  approvedAt    DateTime?
  avatar        String?
  createdAt     DateTime       @default(now())
  machines      Machine[]
  contacts      Contact[]
  consultations Consultation[]
}

model Machine {
  id          String    @id @default(cuid())
  name        String
  category    String
  price       Int
  condition   String
  wilaya      String
  description String?
  specs       String?
  photos      String?
  sellerId    String
  seller      User      @relation(fields: [sellerId], references: [id])
  verified    Boolean   @default(false)
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  contacts    Contact[]
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String
  machineId String?
  machine   Machine? @relation(fields: [machineId], references: [id])
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  status    String   @default("new")
  createdAt DateTime @default(now())
}

model Consultation {
  id           String    @id @default(cuid())
  clientName   String
  clientEmail  String
  clientPhone  String?
  subject      String
  message      String?
  consultantId String?
  consultant   User?     @relation(fields: [consultantId], references: [id])
  status       String    @default("pending")
  scheduledAt  DateTime?
  notes        String?
  createdAt    DateTime  @default(now())
}

model BlogPost {
  id        String   @id
  titre     String
  slug      String   @unique
  categorie String
  contenu   String?
  desc      String?
  image     String?
  tags      String?
  temps     String   @default("5 min")
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Faq {
  id        String   @id
  question  String
  reponse   String
  page      String
  ordre     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Feedback {
  id        String   @id
  nom       String
  poste     String?
  wilaya    String?
  note      Int
  texte     String
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Newsletter {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  createdAt DateTime @default(now())
}

model PrixMarche {
  id       String   @id
  secteur  String
  nom      String
  min      String
  max      String
  tendance String   @default("→")
  pct      String   @default("stable")
  updatedAt DateTime @updatedAt
}

model ConsultingPackage {
  id        String   @id
  titre     String
  prix      String
  duree     String
  desc      String?
  inclus    String?
  badge     String?
  ordre     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model TeamMember {
  id        String   @id
  nom       String
  titre     String
  bio       String?
  wilaya    String?
  avatar    String?
  ordre     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}
